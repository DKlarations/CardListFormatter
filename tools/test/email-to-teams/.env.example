IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=pulllists@example.com
IMAP_PASSWORD=app-password-here
IMAP_MAILBOX=INBOX

TEAMS_WEBHOOK_URL=https://example.webhook.office.com/webhookb2/...

POLL_INTERVAL_SECONDS=60
PROCESSED_STORE=./data/processed-messages.json
SUBJECT_FILTER=pull list
DRY_RUN=true
MARK_PROCESSED_SEEN=false
FORMATTER_BASE_URL=https://card-list-formatter.vercel.app/
MAX_EMAIL_AGE_DAYS=7
